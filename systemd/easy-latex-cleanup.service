[Unit]
Description=easy-latex cleanup task

[Service]
Type=oneshot
User=easylatex
Group=easylatex
WorkingDirectory=/opt/easy-latex
EnvironmentFile=-/etc/easy-latex/easy-latex.env
ExecStart=/usr/bin/node /opt/easy-latex/scripts/cleanup.js
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/easy-latex
